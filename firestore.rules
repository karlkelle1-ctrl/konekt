rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.uid == 'dVIZfTFEbjghmtgKThnzQIBc1dJ3';
    }

    function isAuth() {
      return request.auth != null;
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAdmin()
                  || (isAuth() && (request.auth.uid == userId || resource.data.get('role','') == 'prestataire'));
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAdmin() || (isAuth() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    match /verifications/{docId} {
      allow create: if isAuth();
    }

    match /reviews/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAuth() && request.auth.uid == resource.data.authorUid;
    }

    match /commandes/{cmdId} {
      allow read: if isAdmin()
                  || (isAuth() && (resource == null
                      || request.auth.uid == resource.data.clientUid
                      || request.auth.uid == resource.data.prestataireUid));
      allow write: if isAdmin()
                   || (isAuth() && (resource == null
                       || request.auth.uid == resource.data.clientUid
                       || request.auth.uid == resource.data.prestataireUid));
    }

    match /conversations/{convId} {
      allow read, write: if isAuth() && (
        resource == null ||
        request.auth.uid in resource.data.participants
      );
      match /messages/{msgId} {
        allow read, write: if isAuth();
      }
    }

    match /signalements/{docId} {
      allow create: if isAuth();
      allow read, update, delete: if isAdmin();
    }
  }
}
